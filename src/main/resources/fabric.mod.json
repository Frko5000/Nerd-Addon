{
  "schemaVersion": 1,
  "id": "nerd-addon",
  "version": "${version}",
  "name": "Nerd Addon",
  "description": "Meteor Client Addon For Nerds",
  "authors": [
    "Frko5000",
    "KleinTimmii"
  ],
  "contact": {
    "sources": "https://github.com/Frko5000/nerd-addon"
  },
  "icon": "assets/nerd-addon/icon.png",
